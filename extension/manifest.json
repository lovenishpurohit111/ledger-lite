{
  "manifest_version": 3,
  "name": "FinXport – Financial Statements to Excel",
  "version": "1.0.0",
  "description": "Export P&L, Balance Sheet and Cash Flow from Screener.in to a formatted Excel file in one click.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.screener.in/*",
    "https://screener.in/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.screener.in/company/*", "https://screener.in/company/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
