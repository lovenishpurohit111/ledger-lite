{
  "manifest_version": 3,
  "name": "FinXport \u2013 Financial Statements to Excel",
  "version": "1.4.0",
  "description": "Export P&L, Balance Sheet and Cash Flow from Screener.in, Tickertape & Moneycontrol to Excel in one click.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.screener.in/*",
    "https://screener.in/*",
    "https://www.tickertape.in/*",
    "https://tickertape.in/*",
    "https://www.moneycontrol.com/*",
    "https://moneycontrol.com/*",
    "<all_urls>",
    "file:///*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.screener.in/company/*",
        "https://screener.in/company/*",
        "https://www.tickertape.in/stocks/*",
        "https://tickertape.in/stocks/*",
        "https://www.moneycontrol.com/financials/*",
        "https://www.moneycontrol.com/stocks/*",
        "https://www.moneycontrol.com/india/*",
        "https://www.moneycontrol.com/mutual-funds/*",
        "https://www.moneycontrol.com/prowebmeta/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "finxport@lovenishpurohit",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pdf.min.mjs",
        "pdf.worker.min.mjs",
        "pdf-extractor.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}